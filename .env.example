# Local Supabase connection for server-side Recora data reads.
# Copy to .env.local and fill values from `supabase status`.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-anon-key

# Seeded project slug used by Recora dashboard data helpers.
RECORA_DEFAULT_PROJECT_SLUG=recora-kenzai-q2
