# Local-only example. Do not commit real local keys in .env.local.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=replace-with-local-anon-key-from-supabase-status
SUPABASE_SERVICE_ROLE_KEY=replace-with-local-service-role-key

# Local Postgres connection for import scripts that bypass the Supabase Data API.
RECORA_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
RECORA_DEFAULT_PROJECT_SLUG=recora-kenzai-q2

# OpenAI API key for local inspection scripts. Never commit real keys.
OPENAI_API_KEY=replace-with-openai-api-key
