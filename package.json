{
  "name": "recora-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "recora:whereami": "tsx scripts/recora-dev-checks.ts whereami",
    "recora:human-check": "tsx scripts/recora-dev-checks.ts human-check",
    "recora:before-codex": "tsx scripts/recora-dev-checks.ts before-codex",
    "recora:doctor": "tsx scripts/recora-dev-checks.ts doctor",
    "recora:dashboard-read-model:check": "tsx scripts/recora-dev-checks.ts dashboard-read-model-check",
    "recora:recommendation-publication-surface:check": "tsx scripts/verify-recommendation-publication-surface.ts",
    "recora:project-setup-draft:check": "tsx scripts/verify-recora-project-setup-draft.ts",
    "recora:project-setup-draft-generator:check": "tsx scripts/verify-recora-project-setup-draft-generator.ts",
    "recora:phase1:operator": "tsx scripts/run-recora-phase1-operator-flow.ts",
    "recora:preflight": "npm run recora:whereami && npm run recora:before-codex && npm run recora:doctor && npm run recora:dashboard-read-model:check && npm run recora:recommendation-publication-surface:check && npm run recora:project-setup-draft:check && npm run recora:project-setup-draft-generator:check",
    "recora:preflight:full": "npm run recora:preflight && npm run typecheck",
    "recora:commit-check": "tsx scripts/recora-safe-commit.ts commit-check",
    "recora:safe-commit": "tsx scripts/recora-safe-commit.ts safe-commit"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/supabase-js": "^2.108.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^14.2.0",
    "openai": "^6.43.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.0",
    "postcss": "^8.4.49",
    "supabase": "^2.106.0",
    "tailwindcss": "^3.4.16",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2"
  }
}
